{
    "height": 30,
    "spacing": 6,
    "modules-left": [
        "sway/workspaces",
        "sway/mode",
        "sway/scratchpad"
    ],
    "modules-center": [
        "sway/window"
    ],
    "modules-right": [
        "idle_inhibitor",
        "pulseaudio",
        "network",
        "backlight",
        "sway/language",
        "battery",
        "battery#bat2",
        "clock",
        "tray"
    ],
    "sway/mode": {
        "format": "<span style=\"italic\">{}</span>"
    },
    "sway/scratchpad": {
        "format": "{icon} {count}",
        "show-empty": false,
        "format-icons": [
            "",
            ""
        ],
        "tooltip": true,
        "tooltip-format": "{app}: {title}"
    },
    "idle_inhibitor": {
        "format": "{icon}",
        "format-icons": {
            "activated": "V",
            "deactivated": "X"
        }
    },
    "tray": {
        "spacing": 10
    },
    "clock": {
        "tooltip-format": "<big>{:%Y %B}</big>\n<tt><small>{calendar}</small></tt>",
        "format-alt": "{:%Y-%m-%d}"
    },
    "backlight": {
        "format": "DSP {percent}%"
    },
    "battery": {
        "states": {
            "warning": 30,
            "critical": 15
        },
        "format": "BAT {capacity}%",
        "format-charging": "BAT {capacity}%",
        "format-plugged": "BAT {capacity}%"
    },
    "battery#bat2": {
        "bat": "BAT2"
    },
    "network": {
        "format-wifi": "{essid} ({signalStrength}%) WI",
        "format-ethernet": "{ipaddr}/{cidr} WR",
        "tooltip-format": "{ifname} via {gwaddr} WR",
        "format-linked": "{ifname} (No IP) WR",
        "format-disconnected": "DISCONNECTED",
        "format-alt": "{ifname}: {ipaddr}/{cidr}"
    },
    "pulseaudio": {
        "format":                 "OUT {volume}% {format_source}",
        "format-bluetooth":       "OUT {volume}% BT {format_source}",
        "format-bluetooth-muted": "OUT MT BT {format_source}",
        "format-muted":           "OUT MT {format_source}",
        "format-source":          "MIC {volume}%",
        "format-source-muted":    "MIC MT",
        "on-click":               "pavucontrol"
    }
}